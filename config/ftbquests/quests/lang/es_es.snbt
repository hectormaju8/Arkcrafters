	quest.4C00000000000022.quest_desc: [
		"Trueque &epremium&r: pocas esmeraldas, buena paga en oro."
		""
		"&e2 esmeraldas -> 3 monedas de oro&r · cooldown &620 minutos&r."
	]
	quest.4C00000000000022.quest_subtitle: "2 esmeraldas -> 3 oro (20 min)"
	quest.4C00000000000022.title: "Trueque Premium"
	quest.4C00000000000023.quest_desc: [
		"El &eCajero (ATM)&r es tu &ebanco&r y tu &ecasa de cambio&r. Colócalo en tu colonia y haz clic derecho para abrirlo."
		""
		"Sirve para:"
		"&8-&r &eGuardar monedas&r a salvo (si mueres, lo que está en el banco no se pierde)."
		"&8-&r &eCambiar de tipo&r: junta 100 cobre en 1 oro, o al revés."
		""
		"&aTe regalamos 1 Cajero para empezar.&r Puedes crear más con hierro, cristal y redstone."
	]
	quest.4C00000000000023.quest_subtitle: "Tu banco y casa de cambio"
	quest.4C00000000000023.title: "El Cajero (ATM)"
	quest.4C00000000000024.quest_subtitle: "256 zanahoria -> 12 cobre"
	quest.4C00000000000024.title: "Zanahoria"
	quest.4C00000000000025.quest_subtitle: "4 pasteles -> 24 cobre"
