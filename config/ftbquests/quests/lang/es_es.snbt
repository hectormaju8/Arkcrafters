	quest.6C0000000000000F.quest_subtitle: "Derrota al Nether Gauntlet en HZ IV"
	quest.6C0000000000000F.title: "Jefe HZ IV: Nether Gauntlet"
	quest.6C00000000000010.quest_desc: ["Consigue el logro del mod al derrotar al jefe. Vuelve aqui y pulsa Recompensas (solo una vez)."]
	quest.6C00000000000010.quest_subtitle: "Derrota al Obsidilith en una Zona Caliente IV"
	quest.6C00000000000010.title: "Jefe HZ IV: Obsidilith"
